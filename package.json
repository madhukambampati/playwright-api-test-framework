{
  "name": "playwright-api-test-framework",
  "version": "1.0.0",
  "description": "API-first test automation framework built with Playwright and TypeScript, targeting the Restful Booker API. Demonstrates layered client architecture, runtime schema validation, data factories, and CI integration.",
  "author": "Madhubabu Khambhampati",
  "license": "MIT",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:auth": "playwright test tests/auth",
    "test:bookings": "playwright test tests/bookings",
    "report": "playwright show-report",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "zod": "^3.23.0"
  }
}
